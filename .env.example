# ─── TransPadilla — Variables de entorno ────────────────────────────────────
# Copia este archivo como .env en la raíz del proyecto y completa los valores.
# El archivo .env NUNCA debe subirse a git (ya está en .gitignore).

# ── Base de datos PostgreSQL (obligatorio) ──────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base
# Ejemplo local (Windows/Mac con PostgreSQL instalado):
DATABASE_URL=postgresql://postgres:TU_CONTRASEÑA@localhost:5432/transpadilla

# ── JWT Secret (obligatorio) ────────────────────────────────────────────────
# Cadena aleatoria larga para firmar los tokens de sesión.
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_segura_y_aleatoria

# ── Puertos (opcionales, tienen valores por defecto) ────────────────────────
# Puerto del servidor Express (API + Socket.IO)
PORT=8080

# Puerto del frontend Vite
# VITE_PORT=5173

# ── Producción (opcionales en local) ─────────────────────────────────────────
# NODE_ENV=production hace que Express sirva el frontend ya construido
# (dist/public) en lugar de depender de Vite. En local déjalo sin definir.
# NODE_ENV=production

# SEED_ON_START: si es distinto de "false", al arrancar el servidor crea las
# tablas y carga datos demo cuando la base está vacía. Útil en el primer deploy.
# SEED_ON_START=true

# TRAFICO_URL: a dónde apunta el proxy /api/trafico. En local no hace falta
# (usa http://localhost:8000). En Render se pone la URL pública del servicio
# Django, p.ej. https://transpadilla-trafico.onrender.com
# TRAFICO_URL=

# CORS_ORIGIN: en producción, lista (separada por comas) de orígenes permitidos.
# Como el frontend va same-origin, normalmente NO hace falta definirla.
# CORS_ORIGIN=https://transpadilla-web.onrender.com

# ── Datos iniciales ──────────────────────────────────────────────────────────
# SEED_DEMO=true (por defecto): siembra datos DEMO (rutas, paradas, buses y
#   cuentas de prueba) en una base vacía. Útil para demostraciones.
# SEED_DEMO=false (producción real): NO crea datos demo; crea SOLO un admin con
#   las credenciales de abajo. La app arranca limpia.
# SEED_DEMO=false
# ADMIN_EMAIL=admin@alcaldia.gov.co
# ADMIN_PASSWORD=una_contraseña_segura

# ── Django (microservicio de tráfico) ────────────────────────────────────────
# Django usa la misma DATABASE_URL de arriba.
DJANGO_SECRET_KEY=cambia_esto_por_otra_cadena_secreta
# En producción: desactiva DEBUG y restringe los hosts permitidos.
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://transpadilla-trafico.onrender.com

# ─── INSTRUCCIONES DE SETUP LOCAL ────────────────────────────────────────────
#
# 1. Instala PostgreSQL en tu máquina si no lo tienes:
#    https://www.postgresql.org/download/windows/
#
# 2. Crea la base de datos:
#    psql -U postgres -c "CREATE DATABASE transpadilla;"
#
# 3. Copia este archivo y rellénalo:
#    copy .env.example .env   (Windows)
#    cp .env.example .env     (Mac/Linux)
#
# 4. Instala dependencias:
#    pnpm install
#
# 5. Crea las tablas (migraciones Drizzle):
#    pnpm --filter @workspace/db push
#
# 6. Carga datos de prueba (desde otra terminal, con el servidor corriendo):
#    curl -X POST http://localhost:8080/api/seed
#
# 7. Inicia el servidor API:
#    pnpm --filter @workspace/api-server run dev
#
# 8. Inicia el frontend (en otra terminal):
#    pnpm --filter @workspace/transpadilla run dev
#
# 9. Abre el navegador en: http://localhost:5173
#
# Cuentas demo (después del seed):
#   Admin:     admin@transpadilla.co     / admin123
#   Conductor: conductor@transpadilla.co / conductor123
#   Pasajero:  pasajero@transpadilla.co  / pasajero123
