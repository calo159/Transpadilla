{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "preinstall": "node -e \"var a=process.env.npm_config_user_agent||'';if(!a.startsWith('pnpm')){process.stderr.write('Error: use pnpm, not npm/yarn\\n');process.exit(1)}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:prod": "pnpm --filter @workspace/web run build && pnpm --filter @workspace/api run build",
    "start": "pnpm --filter @workspace/api run start",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./apps/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --if-present run test"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@capacitor/cli>tar": "^7.5.16",
      "replace>minimatch": "^3.1.4",
      "xcode>uuid": "^11.1.1",
      "@esbuild-kit/core-utils>esbuild": "^0.25.0"
    }
  }
}
