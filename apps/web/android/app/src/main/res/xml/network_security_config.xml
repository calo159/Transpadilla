<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Solo HTTPS: bloquea cualquier tráfico en texto plano (cleartext).
         Se confía en las CAs del sistema. No se hace certificate pinning porque
         Render gestiona/rota sus certificados (Google Trust Services) y un pin
         desactualizado dejaría inservibles los APK ya instalados. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
